{
    "name": "lucasdvillegas/laravel-crud-generator",
    "description": "Laravel CRUD generator for Inertia Vue and shadcn applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
        "name": "Lucas Villegas",
        "email": "lucasdavillegas@gmail.com",
        "role": "Developer"
        }
